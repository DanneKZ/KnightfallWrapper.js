// === [ KNIGHTFALL SECURITY - THE UNSTOPPABLE MANUAL FIX ] ===
(function() {
    'use strict';

    const BASE_URL = "https://knightfall-system-bot.onrender.com";
    const VERIFY_API = `${BASE_URL}/api/verify`;

    function launchCinderCrest() {
        console.log("Knightfall ACTIVE!");
        const overlay = document.getElementById('knightfall-overlay');
        if (overlay) overlay.remove();
        alert("🛡️ KNIGHTFALL LOADED SUCCESSFULLY!");
        /* === [ ضع كود المود هنا ] === */
    }

    // فحص إذا كان هناك توكن قديم مخزن
    const savedToken = localStorage.getItem('knightfall_token');
    if (savedToken) {
        verifyToken(savedToken);
    } else {
        createLoginScreen();
    }

    function verifyToken(tk) {
        fetch(`${VERIFY_API}?token=${tk}`)
            .then(res => res.json())
            .then(data => {
                if (data.authorized) launchCinderCrest();
                else createLoginScreen("Invalid or Expired Token.");
            })
            .catch(() => createLoginScreen());
    }

    function createLoginScreen(msg = "") {
        if (document.getElementById('knightfall-overlay')) return;
        const style = document.createElement('style');
        style.textContent = `
            #knightfall-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #0b0c10; z-index: 9999999; display: flex; justify-content: center; align-items: center; font-family: 'Segoe UI', sans-serif; }
            .kf-card { background: #1f2833; padding: 40px; border-radius: 20px; border: 2px solid #66fcf1; text-align: center; color: white; width: 350px; }
            .kf-btn { background: #45a29e; color: white; border: none; padding: 12px; border-radius: 8px; width: 100%; cursor: pointer; font-weight: bold; margin-top: 15px; }
            .kf-input { background: #0b0c10; border: 1px solid #45a29e; color: #66fcf1; width: 100%; padding: 10px; border-radius: 5px; margin-top: 15px; text-align: center; }
        `;
        document.head.appendChild(style);

        const overlay = document.createElement('div');
        overlay.id = "knightfall-overlay";
        overlay.innerHTML = `
            <div class="kf-card">
                <h1 style="color:#66fcf1; margin:0;">KNIGHTFALL</h1>
                <p style="font-size:12px; opacity:0.6;">${msg || "MANUAL ACTIVATION REQUIRED"}</p>
                
                <button class="kf-btn" id="goAuth">1. GET TOKEN (DISCORD)</button>
                
                <input type="text" id="tkInput" class="kf-input" placeholder="PASTE TOKEN HERE">
                <button class="kf-btn" id="saveTk" style="background:#5865F2;">2. ACTIVATE MOD</button>
                
                <p style="font-size:10px; margin-top:10px;">Once you login on Discord, copy the token and paste it above.</p>
            </div>
        `;
        document.body.appendChild(overlay);

        document.getElementById('goAuth').onclick = () => {
            const hwid = btoa(navigator.userAgent).substring(0, 16);
            window.open(`${BASE_URL}/auth/discord?hwid=${hwid}`, "_blank");
        };

        document.getElementById('saveTk').onclick = () => {
            const val = document.getElementById('tkInput').value.trim();
            if (val.length > 50) {
                localStorage.setItem('knightfall_token', val);
                alert("Token Saved! Reloading...");
                location.reload();
            } else {
                alert("Invalid Token! Please copy the whole code.");
            }
        };
    }
})();

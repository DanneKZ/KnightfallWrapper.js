// === [ KNIGHTFALL SECURITY SYSTEM V4 - AUTO-HUNTER EDITION ] ===
// Author: Daniel (DD1_JR)
// Fixed: Forced redirect after successful login

(function() {
    'use strict';

    const BASE_URL = "https://knightfall-system-bot.onrender.com";
    const AUTH_URL = `${BASE_URL}/auth/discord`;
    const VERIFY_API = `${BASE_URL}/api/verify`;

    function launchCinderCrest() {
        console.log("Knightfall: Authentication Successful. Loading Mod...");
        /* === [ PASTE YOUR MOD CODE BELOW ] === */
        alert("Knightfall: CinderCrest Loaded Successfully!");
        /* === [ PASTE YOUR MOD CODE ABOVE ] === */
    }

    // فحص التوكن عند تشغيل الصفحة
    const initialToken = localStorage.getItem('knightfall_token');
    if (initialToken) { 
        verifyToken(initialToken); 
    } else { 
        createLoginScreen(); 
    }

    function verifyToken(tk) {
        fetch(`${VERIFY_API}?token=${tk}`)
            .then(res => res.json())
            .then(data => {
                if (data.authorized) { 
                    launchCinderCrest(); 
                } else { 
                    localStorage.removeItem('knightfall_token'); 
                    createLoginScreen("Session invalid. Please login again."); 
                }
            })
            .catch(() => { createLoginScreen("Server connecting..."); });
    }

    function createLoginScreen(errorMsg = "") {
        const existing = document.getElementById('knightfall-overlay');
        if (existing) existing.remove();

        const style = document.createElement('style');
        style.textContent = `
            @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@800&family=Poppins:wght@300;400;600&display=swap');
            #knightfall-overlay {
                position: fixed; top: 0; left: 0; width: 100%; height: 100%;
                background: radial-gradient(circle at center, #10121a 0%, #050507 100%);
                backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
                z-index: 9999999; display: flex; justify-content: center; align-items: center;
                font-family: 'Poppins', sans-serif;
            }
            .kf-card {
                background: rgba(11, 12, 16, 0.6); padding: 60px 50px; border-radius: 28px;
                border: 1px solid rgba(102, 252, 241, 0.2); text-align: center; max-width: 440px; width: 90%;
            }
            .kf-logo {
                font-family: 'Orbitron', sans-serif; font-size: 42px; font-weight: 800;
                letter-spacing: 8px; margin: 0; background: linear-gradient(90deg, #66fcf1, #ffffff, #66fcf1);
                -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            }
            .kf-subtitle { color: #c5c6c7; font-size: 13px; margin: 15px 0 45px 0; letter-spacing: 2px; text-transform: uppercase; }
            .kf-btn {
                background: transparent; color: #ffffff; border: 2px solid #7289da;
                padding: 18px 30px; border-radius: 14px; font-size: 17px; font-weight: 600;
                cursor: pointer; width: 100%; transition: all 0.3s ease; text-transform: uppercase;
            }
            .kf-btn:hover { background: #7289da; transform: scale(1.02); }
            .kf-error { color: #ff4b2b; font-size: 13px; margin-bottom: 25px; }
        `;
        document.head.appendChild(style);

        const overlay = document.createElement('div');
        overlay.id = "knightfall-overlay";
        overlay.innerHTML = `
            <div class="kf-card">
                <h1 class="kf-logo">KNIGHTFALL</h1>
                <p class="kf-subtitle">Authentication required</p>
                ${errorMsg ? `<div class="kf-error">${errorMsg}</div>` : ''}
                <button class="kf-btn" id="loginBtn">Login with Discord</button>
            </div>
        `;
        document.body.appendChild(overlay);

        document.getElementById('loginBtn').onclick = () => {
            const btn = document.getElementById('loginBtn');
            btn.innerHTML = 'CHECKING AUTH...';
            
            const hwid = btoa(navigator.userAgent + navigator.language).substring(0, 16);
            const authWindow = window.open(`${AUTH_URL}?hwid=${hwid}`, "Knightfall Auth", "width=500,height=750");

            // مراقب ذكي (Hunter): يفحص التوكن كل ثانية حتى لو لم تصل الرسالة
            const hunterInterval = setInterval(() => {
                // إذا وجد التوكن في الـ LocalStorage (الذي يضعه السيرفر عبر الصفحة البيضاء)
                const checkTk = localStorage.getItem('knightfall_token');
                
                if (checkTk) {
                    clearInterval(hunterInterval);
                    if (authWindow) authWindow.close();
                    
                    btn.innerHTML = 'ACCESS GRANTED!';
                    btn.style.borderColor = '#66fcf1';
                    
                    setTimeout(() => {
                        overlay.remove();
                        launchCinderCrest();
                    }, 1000);
                }

                // إذا أغلق النافذة يدوياً ولم يجد توكن، يعيد الزر
                if (authWindow && authWindow.closed && !localStorage.getItem('knightfall_token')) {
                    clearInterval(hunterInterval);
                    btn.innerHTML = 'Login with Discord';
                }
            }, 1000);

            // استماع للرسالة (كطريقة أساسية)
            window.addEventListener('message', (event) => {
                if (event.data && event.data.type === 'knightfall-auth-success') {
                    localStorage.setItem('knightfall_token', event.data.token);
                }
            });
        };
    }
})();

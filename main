// === [ KNIGHTFALL SECURITY V4 - FINAL STABLE ] ===
(function() {
    'use strict';

    const BASE_URL = "https://knightfall-system-bot.onrender.com";
    const VERIFY_API = `${BASE_URL}/api/verify`;

    function launchCinderCrest() {
        // إزالة الواجهة فوراً
        const overlay = document.getElementById('knightfall-overlay');
        if (overlay) overlay.remove();
        console.log("Knightfall: System Online.");
        
        /* === [ ضع كود المود الخاص بك هنا ] === */
        // alert("CinderCrest Loaded!"); 
    }

    const savedToken = localStorage.getItem('knightfall_token');

    // إذا وجدنا توكن، نشغل المود فوراً ولا ننتظر السيرفر (لسرعة الاستجابة)
    if (savedToken && savedToken.length > 50) {
        launchCinderCrest();
        // التحقق في الخلفية فقط للتأكد
        checkInBackground(savedToken);
    } else {
        createLoginScreen();
    }

    function checkInBackground(tk) {
        fetch(`${VERIFY_API}?token=${tk}`)
            .then(res => res.json())
            .then(data => {
                if (!data.authorized) {
                    localStorage.removeItem('knightfall_token');
                    location.reload(); // إذا التوكن مزور، نعيد الصفحة للتسجيل
                }
            }).catch(() => {});
    }

    function createLoginScreen() {
        if (document.getElementById('knightfall-overlay')) return;
        const style = document.createElement('style');
        style.textContent = `
            #knightfall-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #0b0c10; z-index: 9999999; display: flex; justify-content: center; align-items: center; font-family: sans-serif; }
            .kf-card { background: #1f2833; padding: 40px; border-radius: 25px; border: 1px solid #66fcf1; text-align: center; width: 360px; box-shadow: 0 0 30px rgba(102,252,241,0.2); color: white; }
            .kf-btn { background: #5865F2; color: white; border: none; padding: 12px; border-radius: 10px; width: 100%; cursor: pointer; font-weight: bold; margin-bottom: 15px; }
            .kf-input { background: #0b0c10; border: 1px solid #444; color: #66fcf1; width: 100%; padding: 12px; border-radius: 8px; text-align: center; margin-bottom: 10px; outline: none; }
            .kf-activate { background: #45a29e; color: white; border: none; padding: 12px; border-radius: 10px; width: 100%; cursor: pointer; font-weight: bold; }
        `;
        document.head.appendChild(style);

        const overlay = document.createElement('div');
        overlay.id = "knightfall-overlay";
        overlay.innerHTML = `
            <div class="kf-card">
                <h1 style="color:#66fcf1; letter-spacing:4px;">KNIGHTFALL</h1>
                <p style="font-size:12px; opacity:0.7;">MANUAL ACTIVATION REQUIRED</p>
                <button class="kf-btn" id="openAuth">1. GET TOKEN</button>
                <input type="text" id="tokenField" class="kf-input" placeholder="Paste token here...">
                <button class="kf-activate" id="activateBtn">2. ACTIVATE MOD</button>
            </div>
        `;
        document.body.appendChild(overlay);

        document.getElementById('openAuth').onclick = () => {
            const hwid = btoa(navigator.userAgent).substring(0, 16);
            window.open(`${BASE_URL}/auth/discord?hwid=${hwid}`, "_blank");
        };

        document.getElementById('activateBtn').onclick = () => {
            const val = document.getElementById('tokenField').value.trim();
            if (val.length > 50) {
                localStorage.setItem('knightfall_token', val);
                location.reload();
            }
        };
    }
})();

// === [ KNIGHTFALL SECURITY SYSTEM V4 - THE REDIRECT FIX ] ===
(function() {
    'use strict';

    const BASE_URL = "https://knightfall-system-bot.onrender.com";
    const VERIFY_API = `${BASE_URL}/api/verify`;

    function launchCinderCrest() {
        console.log("Knightfall: Auth Success!");
        // هنا تضع كود المود الخاص بك
        alert("ACCESS GRANTED: Welcome to CinderCrest!");
        document.getElementById('knightfall-overlay').remove();
    }

    // [أهم جزء] - التقاط التوكن من الرابط فور العودة من السيرفر
    const urlParams = new URLSearchParams(window.location.search);
    const tokenFromUrl = urlParams.get('token');

    if (tokenFromUrl) {
        localStorage.setItem('knightfall_token', tokenFromUrl);
        // تنظيف الرابط لإزالة التوكن من العنوان
        window.history.replaceState({}, document.title, window.location.pathname);
    }

    const savedToken = localStorage.getItem('knightfall_token');
    if (savedToken) {
        fetch(`${VERIFY_API}?token=${savedToken}`)
            .then(res => res.json())
            .then(data => {
                if (data.authorized) launchCinderCrest();
                else createLoginScreen("Invalid Session.");
            })
            .catch(() => createLoginScreen());
    } else {
        createLoginScreen();
    }

    function createLoginScreen(msg = "") {
        if (document.getElementById('knightfall-overlay')) return;
        const style = document.createElement('style');
        style.textContent = `
            #knightfall-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #050507; z-index: 9999999; display: flex; justify-content: center; align-items: center; font-family: sans-serif; color: white; }
            .kf-card { background: #111; padding: 50px; border-radius: 25px; border: 1px solid #66fcf1; text-align: center; box-shadow: 0 0 20px #66fcf133; }
            .kf-btn { background: #7289da; color: white; border: none; padding: 15px 40px; border-radius: 10px; cursor: pointer; font-weight: bold; margin-top: 20px; font-size: 16px; }
        `;
        document.head.appendChild(style);
        const overlay = document.createElement('div');
        overlay.id = "knightfall-overlay";
        overlay.innerHTML = `<div class="kf-card">
            <h1 style="color:#66fcf1; margin:0;">KNIGHTFALL</h1>
            <p style="opacity:0.6;">${msg || "Authentication Required"}</p>
            <button class="kf-btn" id="loginBtn">LOGIN WITH DISCORD</button>
        </div>`;
        document.body.appendChild(overlay);

        document.getElementById('loginBtn').onclick = () => {
            const hwid = btoa(navigator.userAgent).substring(0, 16);
            window.location.href = `${BASE_URL}/auth/discord?hwid=${hwid}`;
        };
    }
})();
